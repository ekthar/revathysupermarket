# === DATABASE ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/store_db"

# === AUTH (generate: openssl rand -base64 32) ===
NEXTAUTH_SECRET="replace-with-random-secret"
AUTH_SECRET="replace-with-same-secret"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# === STORE BRANDING (fallback if DB not configured) ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="My Supermarket"
NEXT_PUBLIC_STORE_ADDRESS="Kerala, India"
NEXT_PUBLIC_STORE_PHONE="+91 98765 43210"
NEXT_PUBLIC_STORE_WHATSAPP="919876543210"

# === STORE LOCATION (Google Maps → right-click → copy) ===
STORE_LAT="8.644361"
STORE_LNG="76.843472"

# === ADMIN SEED (npm run seed) ===
ADMIN_EMAIL="admin@store.in"
ADMIN_NAME="Store Admin"

# === DELIVERY ===
NEXT_PUBLIC_SERVICEABLE_PINCODES="695121,695122,695123,695124"
NEXT_PUBLIC_DELIVERY_RADIUS="5"

# === CLOUDFLARE R2 (image uploads, optional) ===
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="store-products"
CLOUDFLARE_R2_PUBLIC_URL=""
NEXT_PUBLIC_R2_PUBLIC_URL=""

# === AWS S3 (fallback for logo/avatar if R2 not set) ===
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="store-uploads"

# === WHATSAPP (optional) ===
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_BUSINESS_PHONE="919876543210"

# === GOOGLE LOGIN (optional) ===
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === WEB PUSH (optional, generate: npx web-push generate-vapid-keys) ===
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:admin@store.in"

# === OTP ===
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_10MIN=3
