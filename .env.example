# ╔══════════════════════════════════════════════════════════════╗
# ║           COMPLETE ENV VARIABLES - ALL IN ONE               ║
# ║     Copy this file as .env and fill in your values          ║
# ╚══════════════════════════════════════════════════════════════╝

# ┌──────────────────────────────────────────────────────────────┐
# │ 1. DATABASE (REQUIRED)                                       │
# │    Get free from: neon.tech / supabase.com / railway.app     │
# └──────────────────────────────────────────────────────────────┘
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/store_db"

# ┌──────────────────────────────────────────────────────────────┐
# │ 2. AUTH SECRETS (REQUIRED)                                   │
# │    Generate: openssl rand -base64 32                         │
# │    Both must be the SAME value                               │
# └──────────────────────────────────────────────────────────────┘
NEXTAUTH_SECRET="super-secret-random-key-change-this-in-production"
AUTH_SECRET="super-secret-random-key-change-this-in-production"

# ┌──────────────────────────────────────────────────────────────┐
# │ 3. URLS (REQUIRED - update after deployment)                 │
# │    In production: https://yoursite.vercel.app or domain      │
# └──────────────────────────────────────────────────────────────┘
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ┌──────────────────────────────────────────────────────────────┐
# │ 4. STORE BRANDING (REQUIRED)                                 │
# │    These are FALLBACKS - primary source is Admin Settings DB │
# │    Change the store name here for each new customer          │
# └──────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_STORE_NAME="My Supermarket"
NEXT_PUBLIC_STORE_ADDRESS="Kerala, India"

# ┌──────────────────────────────────────────────────────────────┐
# │ 5. STORE LOCATION (REQUIRED)                                 │
# │    Get from Google Maps: right-click shop → copy coordinates │
# │    Used for delivery distance calculation                    │
# └──────────────────────────────────────────────────────────────┘
STORE_LAT="8.4004"
STORE_LNG="77.0851"

# ┌──────────────────────────────────────────────────────────────┐
# │ 6. ADMIN SEED ACCOUNT (for initial setup)                    │
# │    Used when running: npm run seed                           │
# │    Default password is always: Admin@12345                   │
# │    CHANGE PASSWORD after first login!                        │
# └──────────────────────────────────────────────────────────────┘
ADMIN_EMAIL="admin@store.in"
ADMIN_NAME="Store Admin"

# ┌──────────────────────────────────────────────────────────────┐
# │ 7. DELIVERY PINCODES (REQUIRED)                              │
# │    Comma-separated 6-digit Indian pincodes                   │
# │    Customers outside these pincodes cannot checkout          │
# └──────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_SERVICEABLE_PINCODES="695121,695122,695123,695124,695126"

# ┌──────────────────────────────────────────────────────────────┐
# │ 8. IMAGE UPLOADS - Cloudflare R2 (OPTIONAL)                  │
# │    Only needed if shop wants to upload images from device    │
# │    If not set, admins paste image URLs instead (works fine!) │
# │    Free tier: 10 GB storage, 10M requests/month              │
# └──────────────────────────────────────────────────────────────┘
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="store-products"
CLOUDFLARE_R2_PUBLIC_URL=""

# ┌──────────────────────────────────────────────────────────────┐
# │ 9. IMAGE UPLOADS - AWS S3 (OPTIONAL, alternative to R2)      │
# │    Used for avatar & logo uploads if R2 not configured       │
# └──────────────────────────────────────────────────────────────┘
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="store-uploads"

# ┌──────────────────────────────────────────────────────────────┐
# │ 10. WHATSAPP NOTIFICATIONS (OPTIONAL)                        │
# │     Needs Meta Business account + approved templates         │
# │     Sends order confirmations, OTPs via WhatsApp             │
# └──────────────────────────────────────────────────────────────┘
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_BUSINESS_PHONE="919876543210"

# ┌──────────────────────────────────────────────────────────────┐
# │ 11. GOOGLE LOGIN (OPTIONAL)                                  │
# │     Lets customers sign in with Google                       │
# │     Get from: console.cloud.google.com > Credentials         │
# └──────────────────────────────────────────────────────────────┘
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ┌──────────────────────────────────────────────────────────────┐
# │ 12. WEB PUSH NOTIFICATIONS (OPTIONAL)                        │
# │     Browser push for new order alerts to admin               │
# │     Generate VAPID keys: npx web-push generate-vapid-keys    │
# └──────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:admin@store.in"

# ┌──────────────────────────────────────────────────────────────┐
# │ 13. OTP SETTINGS (OPTIONAL - has sensible defaults)          │
# └──────────────────────────────────────────────────────────────┘
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_10MIN=3
