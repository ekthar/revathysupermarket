# === DATABASE ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/store_db"

# === AUTH (generate with: openssl rand -base64 32) ===
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SECRET="replace-with-the-same-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# === STORE BRANDING ===
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_NAME="My Supermarket"
NEXT_PUBLIC_STORE_ADDRESS="Kerala, India"

# === STORE LOCATION (for distance calculation fallback) ===
STORE_LAT="8.4004"
STORE_LNG="77.0851"

# === ADMIN SEED (used by: npm run seed) ===
ADMIN_EMAIL="admin@store.in"
ADMIN_NAME="Store Admin"
# Default password is always: Admin@12345 (change after first login!)

# === DELIVERY (comma-separated pincodes) ===
NEXT_PUBLIC_SERVICEABLE_PINCODES="695121,695122,695123,695124"

# === IMAGE UPLOADS (Cloudflare R2 or S3-compatible, optional) ===
S3_BUCKET="store-uploads"
CLOUDFLARE_R2_PUBLIC_URL="https://your-public-r2-domain"
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="store-products"

# === WHATSAPP (optional, needs Meta Business API) ===
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_API_TOKEN="your-permanent-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_BUSINESS_PHONE="919876543210"

# === GOOGLE LOGIN (optional) ===
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# === WEB PUSH NOTIFICATIONS (optional) ===
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:admin@store.in"

# === OTP CONFIG ===
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_10MIN=3
