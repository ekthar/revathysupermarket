# ===========================================
# MSM Customer App — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# API URL (your Next.js backend)
# For local development, use your computer's IP (not localhost!)
# Find your IP: Windows → ipconfig | macOS → ifconfig
EXPO_PUBLIC_API_URL=https://revathysupermarket.vercel.app/api

# Google OAuth (from Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
# Only the WEB client ID is required for Expo Go testing
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Optional: Only needed for production native builds (not Expo Go)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
