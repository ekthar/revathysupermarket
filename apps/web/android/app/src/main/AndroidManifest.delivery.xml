<?xml version="1.0" encoding="utf-8"?>
<!--
  Additional permissions for the DELIVERY app variant.
  Merged into AndroidManifest.xml at build time by build-capacitor.yml.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background location: continuous GPS while delivering -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service: keep GPS alive when app is backgrounded -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Exact alarms: wake phone for delivery assignments -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Full-screen intent: show alarm over lock screen -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Boot completed: re-register pending alarms after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery optimization: request exemption so app stays alive -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

</manifest>
