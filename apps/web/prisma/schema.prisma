generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  STAFF
  OWNER
  MANAGER
  PACKING_STAFF
  DELIVERY_PARTNER
}

enum PaymentMethod {
  COD
  UPI_ON_DELIVERY
  WALLET
  CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ReturnStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ITEM_RECEIVED
  REFUNDED
}

enum RefundMethod {
  CASH
  UPI
  GATEWAY
  WALLET
}

enum OrderStatus {
  ORDER_RECEIVED
  AWAITING_CUSTOMER_APPROVAL
  ACCEPTED
  PACKING
  READY_FOR_DELIVERY
  OUT_FOR_DELIVERY
  ARRIVING
  CUSTOMER_UNAVAILABLE
  RETURNED_TO_STORE
  DELIVERED
  CANCELLED
}

enum DeliveryMode {
  ASAP
  SCHEDULED
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  REVERSE
  REFERRAL
  ADJUSTMENT
}

enum ReferralStatus {
  PENDING
  REWARDED
  CANCELLED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CollectionStatus {
  PENDING_HANDOVER
  UPI_AWAITING_VERIFICATION
  SETTLED
  SHORT
  EXCESS
}

enum DamageStatus {
  RECORDED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  phone                  String?                 @unique
  phoneVerified          Boolean                 @default(false)
  role                   Role                    @default(CUSTOMER)
  isActive               Boolean                 @default(true)
  lastLoginAt            DateTime?
  failedLoginAttempts    Int                     @default(0)
  lockedUntil            DateTime?
  passwordVersion        Int                     @default(0)
  vehicleInfo            String?
  currentLatitude        Decimal?                @db.Decimal(9, 6)
  currentLongitude       Decimal?                @db.Decimal(9, 6)
  locationUpdatedAt      DateTime?
  authVersion            Int                     @default(0)
  accounts               Account[]
  sessions               Session[]
  addresses              Address[]
  orders                 Order[]
  assignedOrders         Order[]                 @relation("OrderDeliveryPartner")
  acknowledgedOrders     Order[]                 @relation("OrderAcknowledgedBy")
  pushSubscriptions      PushSubscription[]
  auditLogs              AuditLog[]
  orderEditLogs          OrderEditLog[]
  resolvedReturns        ReturnRequest[]         @relation("ReturnResolvedBy")
  walletTransactions     WalletTransaction[]
  passwordResetTokens    PasswordResetToken[]
  otpTokens              OtpToken[]
  favorites              Favorite[]
  settings               UserSettings?
  notifications          Notification[]
  loyaltyAccount         LoyaltyAccount?
  loyaltyTransactions    LoyaltyTransaction[]
  promoRedemptions       PromoRedemption[]
  referralsMade          Referral[]              @relation("ReferralReferrer")
  referralReceived       Referral?               @relation("ReferralReferred")
  supportTickets         SupportTicket[]         @relation("SupportCustomer")
  assignedSupportTickets SupportTicket[]         @relation("SupportAssignee")
  supportMessages        SupportMessage[]
  feedback               OrderFeedback[]
  deliveryLocationEvents DeliveryLocationEvent[]
  staffPermissions       StaffPermission[]
  deliveryCollections    DeliveryCollection[]    @relation("CollectionPartner")
  reconciledCollections  DeliveryCollection[]    @relation("CollectionReconciler")
  deliveryAdjustments    DeliveryAdjustment[]
  referralCode           String?                 @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model OtpToken {
  id        String    @id @default(cuid())
  phone     String
  tokenHash String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([phone, expiresAt])
  @@index([userId])
}

model WhatsAppLog {
  id        String    @id @default(cuid())
  phone     String
  orderId   String?
  template  String
  messageId String?
  status    String    @default("sent")
  error     String?
  statusAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([orderId])
  @@index([phone])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sortOrder])
}

model Product {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String
  image         String
  price         Decimal     @db.Decimal(10, 2)
  discountPrice Decimal?    @db.Decimal(10, 2)
  costPrice     Decimal?    @db.Decimal(10, 2)
  brand         String?
  stock         Int         @default(0)
  popularity    Int         @default(0)
  unit          String
  isActive      Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  gstRate       Decimal?    @db.Decimal(5, 2)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  favorites     Favorite[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([isActive])
  @@index([isFeatured])
  @@index([categoryId])
  @@index([popularity])
  @@index([createdAt])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  houseName String
  street    String
  landmark  String
  pincode   String
  latitude  Decimal  @db.Decimal(9, 6)
  longitude Decimal  @db.Decimal(9, 6)
  isDefault Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                      String                  @id @default(cuid())
  orderNumber             String                  @unique
  userId                  String?
  customerName            String
  phone                   String
  houseName               String
  street                  String
  landmark                String
  pincode                 String
  notes                   String?
  latitude                Decimal                 @db.Decimal(9, 6)
  longitude               Decimal                 @db.Decimal(9, 6)
  distanceKm              Decimal                 @db.Decimal(6, 2)
  paymentMethod           PaymentMethod
  paymentStatus           PaymentStatus           @default(PENDING)
  status                  OrderStatus             @default(ORDER_RECEIVED)
  subtotal                Decimal                 @db.Decimal(10, 2)
  discount                Decimal                 @default(0) @db.Decimal(10, 2)
  deliveryFee             Decimal                 @default(0) @db.Decimal(10, 2)
  deliveryFeeSlabId       String?
  deliveryFeeMinKm        Decimal?                @db.Decimal(6, 2)
  deliveryFeeMaxKm        Decimal?                @db.Decimal(6, 2)
  total                   Decimal                 @db.Decimal(10, 2)
  acknowledgedAt          DateTime?
  acknowledgedById        String?
  editApprovalStatus      String?
  editApprovalRequestedAt DateTime?
  deliveryPartnerId       String?
  deliveryAssignedAt      DateTime?
  deliveryAlertAckAt      DateTime?
  deliveryOtp             String?
  deliveryOtpAttempts     Int                     @default(0)
  deliveryOtpExpiresAt    DateTime?
  deliveryConfirmedAt     DateTime?
  customerUnavailableAt  DateTime?
  customerUnavailableTimeout Int?
  billNumber              String?
  staffNote               String?
  printCount              Int                     @default(0)
  printedAt               DateTime?
  printedById             String?
  deliveryMode            DeliveryMode            @default(ASAP)
  deliverySlotId          String?
  estimatedDeliveryAt     DateTime?
  loyaltyPointsRedeemed   Int                     @default(0)
  loyaltyPointsEarned     Int                     @default(0)
  user                    User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  acknowledgedBy          User?                   @relation("OrderAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)
  deliveryPartner         User?                   @relation("OrderDeliveryPartner", fields: [deliveryPartnerId], references: [id], onDelete: SetNull)
  items                   OrderItem[]
  statusEvents            OrderEvent[]
  editLogs                OrderEditLog[]
  returnRequests          ReturnRequest[]
  walletTransactions      WalletTransaction[]
  deliverySlot            DeliverySlot?           @relation(fields: [deliverySlotId], references: [id], onDelete: SetNull)
  loyaltyTransactions     LoyaltyTransaction[]
  promoRedemptions        PromoRedemption[]
  supportTickets          SupportTicket[]
  feedback                OrderFeedback?
  deliveryLocationEvents  DeliveryLocationEvent[]
  deliveryCollection      DeliveryCollection?
  deliveryAdjustments     DeliveryAdjustment[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([status])
  @@index([acknowledgedAt])
  @@index([acknowledgedById])
  @@index([deliveryPartnerId])
  @@index([deliveryPartnerId, deliveryAlertAckAt])
  @@index([createdAt])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([deliverySlotId])
  @@index([estimatedDeliveryAt])
}

model OrderItem {
  id                  String               @id @default(cuid())
  orderId             String
  productId           String?
  name                String
  quantity            Int
  price               Decimal              @db.Decimal(10, 2)
  gstRate             Decimal?             @db.Decimal(5, 2)
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product?             @relation(fields: [productId], references: [id], onDelete: SetNull)
  deliveryAdjustments DeliveryAdjustment[]

  @@index([orderId])
  @@index([productId])
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
}

model OrderEditLog {
  id                       String    @id @default(cuid())
  orderId                  String
  editedById               String?
  action                   String
  originalItem             Json?
  newItem                  Json?
  priceDelta               Decimal   @default(0) @db.Decimal(10, 2)
  reason                   String?
  requiresCustomerApproval Boolean   @default(false)
  customerDecision         String?
  decidedAt                DateTime?
  order                    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  editedBy                 User?     @relation(fields: [editedById], references: [id], onDelete: SetNull)
  createdAt                DateTime  @default(now())

  @@index([orderId])
  @@index([editedById])
  @@index([createdAt])
}

model ReturnRequest {
  id                String             @id @default(cuid())
  returnNumber      String             @unique @default(cuid())
  orderId           String
  billNumber        String             @default("")
  items             Json
  reason            String
  photoUrl          String?
  evidenceUrls      String[]
  note              String?
  status            ReturnStatus       @default(REQUESTED)
  refundMethod      RefundMethod?
  refundAmount      Decimal?           @db.Decimal(10, 2)
  maxRefundAmount   Decimal?           @db.Decimal(10, 2)
  refundReference   String?
  resolutionNote    String?
  rejectionReason   String?
  resolvedById      String?
  resolvedAt        DateTime?
  itemReceivedAt    DateTime?
  refundedAt        DateTime?
  eligibleUntil     DateTime?
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  resolvedBy        User?              @relation("ReturnResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  walletTransaction WalletTransaction?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([orderId, status])
  @@index([resolvedById])
  @@index([createdAt])
  @@index([returnNumber])
  @@index([billNumber])
}

model WalletTransaction {
  id              String         @id @default(cuid())
  userId          String
  orderId         String?
  returnRequestId String?        @unique
  amount          Decimal        @db.Decimal(10, 2)
  type            String
  reason          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order           Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  returnRequest   ReturnRequest? @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([returnRequestId])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Banner {
  id        String    @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  href      String?
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  pushNotifications     Boolean  @default(true)
  orderUpdates          Boolean  @default(true)
  promotionalMessages   Boolean  @default(false)
  whatsappNotifications Boolean  @default(true)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("order")
  orderId   String?
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model PromoCode {
  id            String            @id @default(cuid())
  code          String            @unique
  description   String?
  discountType  String            @default("percentage")
  discountValue Decimal           @db.Decimal(10, 2)
  minimumOrder  Decimal           @default(0) @db.Decimal(10, 2)
  maxDiscount   Decimal?          @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int               @default(0)
  isActive      Boolean           @default(true)
  startsAt      DateTime?
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  redemptions   PromoRedemption[]

  @@index([code])
  @@index([isActive, expiresAt])
}

model DeliverySlot {
  id          String   @id @default(cuid())
  serviceDate DateTime @db.Date
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int
  bookedCount Int      @default(0)
  isActive    Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([serviceDate, startsAt, endsAt])
  @@index([serviceDate, isActive])
}

model LoyaltyAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LoyaltyTransaction {
  id        String                 @id @default(cuid())
  userId    String
  orderId   String?
  type      LoyaltyTransactionType
  points    Int
  reason    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt DateTime               @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
}

model Referral {
  id             String         @id @default(cuid())
  referrerId     String
  referredUserId String         @unique
  status         ReferralStatus @default(PENDING)
  rewardedAt     DateTime?
  referrer       User           @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser   User           @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@index([referrerId, status])
}

model PromoRedemption {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  orderId     String
  discount    Decimal   @db.Decimal(10, 2)
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([promoCodeId, userId])
  @@index([promoCodeId, createdAt])
  @@index([userId])
}

model SupportTicket {
  id           String              @id @default(cuid())
  ticketNumber String              @unique
  customerId   String
  orderId      String?
  assigneeId   String?
  subject      String
  status       SupportTicketStatus @default(OPEN)
  priority     SupportPriority     @default(NORMAL)
  customer     User                @relation("SupportCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  order        Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignee     User?               @relation("SupportAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages     SupportMessage[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([customerId, createdAt])
  @@index([status, priority])
  @@index([assigneeId])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  authorId  String
  body      String        @db.Text
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt])
}

model OrderFeedback {
  id             String   @id @default(cuid())
  orderId        String   @unique
  userId         String
  orderRating    Int
  deliveryRating Int
  tags           String[]
  comment        String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model DeliveryLocationEvent {
  id                String   @id @default(cuid())
  orderId           String
  deliveryPartnerId String
  latitude          Decimal  @db.Decimal(9, 6)
  longitude         Decimal  @db.Decimal(9, 6)
  heading           Float?
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryPartner   User     @relation(fields: [deliveryPartnerId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([deliveryPartnerId, createdAt])
}

model Offer {
  id            String    @id @default(cuid())
  title         String
  description   String?
  discountType  String    @default("percentage") // percentage or fixed
  discountValue Decimal   @db.Decimal(10, 2)
  categoryId    String?
  productId     String?
  minQuantity   Int       @default(1)
  maxDiscount   Decimal?  @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  startsAt      DateTime?
  expiresAt     DateTime?
  image         String?
  badge         String? // e.g. "20% OFF", "BUY 2 GET 1"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, expiresAt])
  @@index([categoryId])
  @@index([productId])
}

model StaffPermission {
  id         String   @id @default(cuid())
  userId     String
  permission String
  grantedBy  String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
  @@index([permission])
}

model DeliveryFeeSlab {
  id        String   @id @default(cuid())
  minKm     Decimal  @db.Decimal(6, 2)
  maxKm     Decimal  @db.Decimal(6, 2)
  fee       Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, minKm])
}

model DeliveryAdjustment {
  id              String       @id @default(cuid())
  orderId         String
  orderItemId     String?
  partnerId       String
  itemName        String
  quantity        Int
  reason          String
  reductionAmount Decimal      @db.Decimal(10, 2)
  evidenceUrl     String?
  status          DamageStatus @default(RECORDED)
  approvedById    String?
  approvedAt      DateTime?
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem       OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  partner         User         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([orderId])
  @@index([orderItemId])
  @@index([partnerId])
  @@index([status])
}

model DeliveryCollection {
  id                  String           @id @default(cuid())
  orderId             String           @unique
  partnerId           String
  expectedAmount      Decimal          @db.Decimal(10, 2)
  cashCollected       Decimal          @default(0) @db.Decimal(10, 2)
  upiCollected        Decimal          @default(0) @db.Decimal(10, 2)
  walletApplied       Decimal          @default(0) @db.Decimal(10, 2)
  adjustmentAmount    Decimal          @default(0) @db.Decimal(10, 2)
  upiReference        String?
  status              CollectionStatus @default(PENDING_HANDOVER)
  discrepancyReason   String?
  reconciledById      String?
  reconciledAt        DateTime?
  completionReference String?          @unique
  completedAt         DateTime?
  order               Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partner             User             @relation("CollectionPartner", fields: [partnerId], references: [id], onDelete: Cascade)
  reconciledBy        User?            @relation("CollectionReconciler", fields: [reconciledById], references: [id], onDelete: SetNull)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([partnerId, createdAt])
  @@index([status])
  @@index([reconciledById])
}

model MobileRefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  deviceId  String
  platform  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([deviceId, revokedAt, expiresAt])
}

model DeviceToken {
  id             String   @id @default(cuid())
  userId         String
  platform       String
  role           String   @default("customer")
  installationId String   @unique
  token          String
  lastSeenAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, installationId])
  @@index([token])
  @@index([role])
}

model AssignmentEvent {
  id             String    @id @default(cuid())
  eventId        String    @unique
  orderId        String
  partnerId      String
  orderNumber    String
  assignedAt     DateTime
  acknowledgedAt DateTime?
  fcmSent        Boolean   @default(false)
  fcmSentAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([partnerId, acknowledgedAt])
  @@index([orderId])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
